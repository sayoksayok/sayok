# ===========================================
# MAINNET (Production: https://www.sayok.chat)
# Set these in Vercel: Project > Settings > Environment Variables
# ===========================================

# Public site URL (Open Graph / absolute URLs; defaults to https://www.sayok.chat in layout if unset)
NEXT_PUBLIC_SITE_URL=https://www.sayok.chat

# Anthropic API Key (required for SayOK / Claude)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Lead discovery workflow (/new-deal)
# Brave finds real organizations, Firecrawl reads sites, Hunter finds/verifies emails.
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
HUNTER_API_KEY=your_hunter_api_key_here
APOLLO_API_KEY=your_optional_apollo_api_key_here

# Mantle Sepolia escrow demo (/new-deal/settlement)
# Disabled unless explicitly set to true. Testnet only. Do not use mainnet funds.
NEXT_PUBLIC_ESCROW_DEMO=false
NEXT_PUBLIC_MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
NEXT_PUBLIC_ESCROW_CONTRACT_ADDRESS=0x_your_mantle_sepolia_escrow_contract
NEXT_PUBLIC_ESCROW_TOKEN_ADDRESS=0x_your_testnet_usdc_or_mock_erc20
NEXT_PUBLIC_ESCROW_TOKEN_DECIMALS=6
NEXT_PUBLIC_ESCROW_DEMO_PAYEE=0x1111111111111111111111111111111111111111
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
ESCROW_ERC20_ADDRESS=0x_your_testnet_usdc_or_mock_erc20
DEPLOYER_PRIVATE_KEY=never_commit_real_private_keys

# ElevenLabs API Key (Optional - for TTS; if unset, browser TTS is used)
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Supabase (required for login, history, Pro)
# Get from: https://supabase.com/dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role (server only — never expose to the browser). Used for Stripe webhooks,
# daily usage RPC, and server-side lead intent logging/email-gate capture.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Stripe subscriptions (required for /pro checkout)
STRIPE_SECRET_KEY=sk_live_or_test_key_here
STRIPE_PRICE_MONTHLY=price_monthly_id_here
STRIPE_PRICE_YEARLY=price_yearly_id_here
STRIPE_WEBHOOK_SECRET=whsec_webhook_secret_here

# Optional: salt for hashing guest IPs for daily limits (defaults to a slice of service role key if unset)
SAYOK_USAGE_SALT=

# After first deploy, run SQL migrations in supabase/migrations/ in Supabase Dashboard
# → SQL Editor so daily limits and lead intent tables are available server-side.
